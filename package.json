{
  "name": "pomodoro-timer",
  "version": "1.1.0",
  "private": true,
  "description": "A configurable pomodoro-like timer",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "lint": "eslint 'src/**/*.*'",
    "serve": "vite preview"
  },
  "dependencies": {
    "pinia": "2.0.0-rc.6",
    "prettier": "2.3.2",
    "tailwindcss": "2.2.8",
    "uid": "2.0.0",
    "vue": "3.2.6",
    "vue-types": "4.0.3"
  },
  "devDependencies": {
    "@types/node": "14.17.12",
    "@typescript-eslint/eslint-plugin": "4.29.3",
    "@typescript-eslint/parser": "4.29.3",
    "@vitejs/plugin-vue": "1.6.0",
    "@vue/compiler-sfc": "3.2.6",
    "autoprefixer": "10.3.3",
    "eslint": "7.32.0",
    "eslint-config-prettier": "8.3.0",
    "eslint-plugin-prettier": "3.4.1",
    "eslint-plugin-vue": "7.17.0",
    "postcss": "8.3.6",
    "typescript": "4.4.2",
    "vite": "2.5.1",
    "vite-plugin-pwa": "0.11.2",
    "vite-svg-loader": "2.2.0",
    "vue-tsc": "0.3.0"
  },
  "prettier": {
    "trailingComma": "all",
    "arrowParens": "always",
    "semi": true,
    "singleQuote": true
  }
}
